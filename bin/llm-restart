#!/usr/bin/env bash
# llm-restart — restart one or all MacStudioLLM services.
#
# Usage:
#   llm-restart                 # restart every always-on service
#   llm-restart ollama          # restart ollama only
#   llm-restart immich docling  # multiple
#   llm-restart all             # explicit "all"
#   llm-restart list            # show known service names
set -u

# Self-elevate: launchctl kickstart on system/ domain needs root.
if [ "$(id -u)" -ne 0 ]; then
  exec sudo "$0" "$@"
fi

# Short-name → launchd label (Bash-3.2 safe; macOS ships /bin/bash 3.2).
label_for() {
  case "$1" in
    ollama)          echo com.local.ollama.headless ;;
    immich-proxy)    echo com.local.immich.proxy ;;
    immich)          echo com.local.immich.ml ;;
    docling-proxy)   echo com.local.docling.proxy ;;
    docling)         echo com.local.docling.serve ;;
    node)            echo com.local.node.exporter ;;
    silicon)         echo com.local.silicon.exporter ;;
    ollama-exporter) echo com.local.ollama.exporter ;;
    watchdog)        echo com.local.llm.watchdog ;;
    preventsleep)    echo com.local.preventsleep ;;
    *)               echo "" ;;
  esac
}

ALL_SHORT_NAMES=(ollama immich-proxy immich docling-proxy docling \
                 node silicon ollama-exporter watchdog preventsleep)
ALL_ALWAYS_ON=(ollama immich-proxy docling-proxy node silicon ollama-exporter watchdog preventsleep)

if [ $# -eq 0 ] || [ "${1:-}" = all ]; then
  set -- "${ALL_ALWAYS_ON[@]}"
fi

if [ "${1:-}" = list ]; then
  printf "%-20s %s\n" NAME LABEL
  for k in "${ALL_SHORT_NAMES[@]}"; do printf "%-20s %s\n" "$k" "$(label_for "$k")"; done
  exit 0
fi

rc=0
for name in "$@"; do
  label=$(label_for "$name")
  if [ -z "$label" ]; then
    echo "unknown service: $name (try: llm-restart list)" >&2
    rc=1
    continue
  fi
  if /bin/launchctl print "system/$label" >/dev/null 2>&1; then
    /bin/launchctl kickstart -k "system/$label" && echo "restarted: $name ($label)"
  else
    echo "not registered: $name ($label)" >&2
    rc=1
  fi
done
exit "$rc"
