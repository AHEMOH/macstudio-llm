#!/usr/bin/env bash
# llm-update — run the weekly autoupdate job NOW.
# Same code path as the Saturday 06:00 scheduled run.
set -u

if [ "$(id -u)" -ne 0 ]; then
  exec sudo "$0" "$@"
fi

SCRIPT=/usr/local/sbin/weekly-autoupdate.sh
if [ ! -x "$SCRIPT" ]; then
  echo "not found: $SCRIPT — run setup.sh first" >&2
  exit 1
fi
exec /bin/bash "$SCRIPT" "$@"
