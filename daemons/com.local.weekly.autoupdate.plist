<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.local.weekly.autoupdate</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/usr/local/sbin/weekly-autoupdate.sh</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key><integer>@AUTOUPDATE_WEEKDAY@</integer>
    <key>Hour</key><integer>@AUTOUPDATE_HOUR@</integer>
    <key>Minute</key><integer>@AUTOUPDATE_MINUTE@</integer>
  </dict>
  <key>RunAtLoad</key><false/>
  <key>KeepAlive</key><false/>
  <key>StandardOutPath</key><string>/var/log/macstudio/autoupdate.log</string>
  <key>StandardErrorPath</key><string>/var/log/macstudio/autoupdate.log</string>
</dict>
</plist>
