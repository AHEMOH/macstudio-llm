        { "refId": "A", "expr": "node_time_seconds - node_boot_time_seconds", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] },
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "value" }
    },

    {
      "type": "state-timeline",
      "id": 40,
      "title": "On-demand backend state",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "expr": "ondemand_backend_up", "legendFormat": "{{service}}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "asleep", "color": "dark-blue" }, "1": { "text": "awake", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "dark-blue", "value": null }, { "color": "green", "value": 1 } ] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "mergeValues": true, "showValue": "auto", "alignValue": "left", "rowHeight": 0.8, "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } }
    },
    {
      "type": "table",
      "id": 41,
      "title": "Scrape targets",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 64 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        { "refId": "A", "instant": true, "format": "table", "expr": "up{job=~\"mac-.*\"}", "datasource": { "type": "prometheus", "uid": "${datasource}" } }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true }, "indexByName": { "job": 0, "Value": 1 }, "renameByName": { "job": "Job", "Value": "Up" } } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Up" }, "properties": [
            { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] },
            { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }
          ] }
        ]
      },
      "options": { "showHeader": true }
    },
